# Copy to .env.local (gitignored):  cp .env.local.example .env.local
#
# Local Firestore emulator — no GCP account needed.
# The emulator treats "demo-*" project ids as fully offline (no auth, no billing).
# Unset these (and the emulator) to talk to real Firestore via ADC (e.g. on Cloud Run).
FIRESTORE_EMULATOR_HOST=127.0.0.1:8910
GCLOUD_PROJECT=demo-ketrone
# Throwaway local key (emulator ignores the token) so the REST transport can
# sign a self-signed JWT offline. Generate it with:  npm run gen:key
GOOGLE_APPLICATION_CREDENTIALS=firebase-emulator-sa.json
